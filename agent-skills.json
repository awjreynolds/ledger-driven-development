{
  "schemaVersion": "1.0",
  "name": "ledger-driven-development",
  "displayName": "Ledger-Driven Development",
  "version": "0.1.0",
  "description": "Agent-agnostic skills for repo-local ledger product, design, planning, decomposition, and implementation handoffs.",
  "license": "MIT",
  "repository": "https://github.com/awjreynolds/ledger-driven-development",
  "canonicalSkillRoot": "skills",
  "ledger": {
    "type": "repo-local",
    "stateSource": "docs/tickets/**/ledger.yml"
  },
  "commands": [
    {
      "command": "/ldd:setup",
      "skill": "ldd-setup",
      "path": "skills/ldd-setup",
      "purpose": "Bootstrap LDD files and local ledger support in a target repository."
    },
    {
      "command": "/ldd:next",
      "skill": "ldd-next",
      "path": "skills/ldd-next",
      "purpose": "Read repo-local ledger state and report the next LDD command."
    },
    {
      "command": "/ldd:scope",
      "skill": "ldd-scope",
      "path": "skills/ldd-scope",
      "purpose": "Write PRD goals, non-goals, and initial constraints."
    },
    {
      "command": "/ldd:elaborate",
      "skill": "ldd-elaborate",
      "path": "skills/ldd-elaborate",
      "purpose": "Fill product detail inside the approved scope."
    },
    {
      "command": "/ldd:refine",
      "skill": "ldd-refine",
      "path": "skills/ldd-refine",
      "purpose": "Make the PRD testable and ready for engineering design review."
    },
    {
      "command": "/ldd:design",
      "skill": "ldd-design",
      "path": "skills/ldd-design",
      "purpose": "Write the SDD and apply the ADR threshold."
    },
    {
      "command": "/ldd:plan",
      "skill": "ldd-plan",
      "path": "skills/ldd-plan",
      "purpose": "Write the implementation plan and generated HTML review copy."
    },
    {
      "command": "/ldd:decompose",
      "skill": "ldd-decompose",
      "path": "skills/ldd-decompose",
      "purpose": "Create child vertical-slice tickets from an approved plan."
    },
    {
      "command": "/ldd:implement",
      "skill": "ldd-implement",
      "path": "skills/ldd-implement",
      "purpose": "Implement one ready child vertical-slice ticket with code and tests."
    },
    {
      "command": "/ldd:verify",
      "skill": "ldd-verify",
      "path": "skills/ldd-verify",
      "purpose": "Verify one implemented child ticket is ready for human-approved closure."
    },
    {
      "command": "/ldd:close",
      "skill": "ldd-close",
      "path": "skills/ldd-close",
      "purpose": "Apply human-approved closure for one verified child ticket."
    }
  ],
  "adapters": {
    "codex": {
      "type": "agent-skills",
      "install": "Use $skill-installer with the canonical skill paths in this manifest."
    },
    "claude": {
      "type": "claude-code-plugin",
      "pluginManifest": ".claude-plugin/plugin.json",
      "marketplaceManifest": ".claude-plugin/marketplace.json",
      "commands": "commands/ldd/*.md"
    },
    "gemini": {
      "type": "gemini-cli-extension",
      "extensionManifest": "gemini-extension.json",
      "context": "GEMINI.md",
      "commands": "commands/ldd/*.toml"
    }
  }
}
